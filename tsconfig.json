{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@pages/*": [
                "pages/*"
            ]
        }
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}